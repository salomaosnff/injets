{
  "name": "@injets/functional",
  "version": "1.1.2",
  "description": "Use injets Dependency Injection with functional factories",
  "repository": "https://github.com/salomaosnff/injets",
  "author": "Salomão Neto <salomaosnff@yahoo.com>",
  "license": "MIT",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "browser": {
        "types": "./dist/index.browser.d.ts",
        "import": "./dist/index.browser.mjs",
        "require": "./dist/index.browser.cjs"
      },
      "default": {
        "types": "./dist/index.browser.d.ts",
        "import": "./dist/index.browser.mjs",
        "require": "./dist/index.browser.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "example": "tsx ./example/index.ts",
    "build": "tsup",
    "prepublish": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^3.14.0",
    "typescript": "^5.2.2"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
